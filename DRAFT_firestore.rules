rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE UTILITIES & ATTRIBUTE-BASED ACCESS CONTROL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "ADMIN"
      );
    }

    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "TEACHER"
      );
    }

    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "ADMIN" ||
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "TEACHER"
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- COLLECTION MATCHES & VALIDATIONS ---

    // 1. Notices Collection
    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isStaff() && isValidNotice(request.resource.data);
      allow update: if isStaff() && isValidNotice(request.resource.data);
      allow delete: if isStaff();
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['titleEn', 'titleHi', 'contentEn', 'contentHi', 'category', 'publishedDate', 'isUrgent', 'isPinned', 'author']) 
        && data.titleEn is string && data.titleEn.size() <= 200
        && data.titleHi is string && data.titleHi.size() <= 200
        && data.contentEn is string && data.contentEn.size() <= 4000
        && data.contentHi is string && data.contentHi.size() <= 4000
        && data.category is string
        && data.publishedDate is string
        && data.isUrgent is bool
        && data.isPinned is bool
        && data.author is string;
    }

    // 2. Students Collection
    match /students/{studentId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.email == request.auth.token.email);
      allow create: if isAdmin() && isValidStudent(request.resource.data);
      allow update: if isStaff() && isValidStudent(request.resource.data) && (
        isAdmin() || (
          // Staff can update specific fields like DBT and Medhasoft statuses
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['medhasoftStatus', 'dbtPaymentStatus'])
        )
      );
      allow delete: if isAdmin();
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['rollNo', 'nameEn', 'nameHi', 'className', 'section', 'fatherNameEn', 'fatherNameHi', 'motherNameEn', 'motherNameHi', 'dob', 'category', 'bankAccountLast4', 'ifscCode', 'medhasoftStatus', 'dbtPaymentStatus'])
        && data.rollNo is string && data.rollNo.size() <= 32
        && data.nameEn is string && data.nameEn.size() <= 200
        && data.nameHi is string && data.nameHi.size() <= 200
        && data.className is string
        && data.section is string
        && data.fatherNameEn is string && data.fatherNameEn.size() <= 200
        && data.fatherNameHi is string && data.fatherNameHi.size() <= 200
        && data.motherNameEn is string && data.motherNameEn.size() <= 200
        && data.motherNameHi is string && data.motherNameHi.size() <= 200
        && data.dob is string
        && data.category is string
        && data.bankAccountLast4 is string && data.bankAccountLast4.size() <= 16
        && data.ifscCode is string && data.ifscCode.size() <= 16
        && data.medhasoftStatus is string
        && data.dbtPaymentStatus is string;
    }

    // 3. Exam Results Collection
    match /examResults/{resultId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.studentEmail == request.auth.token.email);
      allow create: if isStaff() && isValidResult(request.resource.data);
      allow update: if isStaff() && isValidResult(request.resource.data);
      allow delete: if isStaff();
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentId', 'examNameEn', 'examNameHi', 'academicYear', 'totalPercentage', 'grade', 'resultStatus', 'remarksEn', 'remarksHi'])
        && data.studentId is string
        && data.examNameEn is string && data.examNameEn.size() <= 200
        && data.examNameHi is string && data.examNameHi.size() <= 200
        && data.academicYear is string
        && data.totalPercentage is number
        && data.grade is string
        && data.resultStatus is string
        && data.remarksEn is string
        && data.remarksHi is string;
    }

    // 4. Attendance Records
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.studentEmail == request.auth.token.email);
      allow create: if isStaff() && isValidAttendance(request.resource.data);
      allow update: if isStaff() && isValidAttendance(request.resource.data);
      allow delete: if isStaff();
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['studentId', 'date', 'status', 'className', 'section'])
        && data.studentId is string
        && data.date is string
        && data.status is string
        && data.className is string
        && data.section is string;
    }

    // 5. Homework Collection
    match /homework/{homeworkId} {
      allow read: if true;
      allow create: if isStaff() && isValidHomework(request.resource.data);
      allow update: if isStaff() && isValidHomework(request.resource.data);
      allow delete: if isStaff();
    }

    function isValidHomework(data) {
      return data.keys().hasAll(['titleEn', 'titleHi', 'descriptionEn', 'descriptionHi', 'className', 'section', 'subjectEn', 'subjectHi', 'assignedDate', 'dueDate', 'teacherName'])
        && data.titleEn is string && data.titleEn.size() <= 200
        && data.titleHi is string && data.titleHi.size() <= 200
        && data.descriptionEn is string
        && data.descriptionHi is string
        && data.className is string
        && data.section is string
        && data.subjectEn is string
        && data.subjectHi is string
        && data.assignedDate is string
        && data.dueDate is string
        && data.teacherName is string;
    }

    // 6. Study Materials Collection
    match /studyMaterials/{materialId} {
      allow read: if true;
      allow create: if isStaff() && isValidStudyMaterial(request.resource.data);
      allow update: if isStaff() && isValidStudyMaterial(request.resource.data);
      allow delete: if isStaff();
    }

    function isValidStudyMaterial(data) {
      return data.keys().hasAll(['titleEn', 'titleHi', 'className', 'subjectEn', 'subjectHi', 'uploadedDate', 'isELots'])
        && data.titleEn is string && data.titleEn.size() <= 200
        && data.titleHi is string && data.titleHi.size() <= 200
        && data.className is string
        && data.subjectEn is string
        && data.subjectHi is string
        && data.uploadedDate is string
        && data.isELots is bool;
    }

    // 7. Grievances Collection
    match /grievances/{grievanceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.complainantEmail == request.auth.token.email);
      allow create: if isValidGrievance(request.resource.data);
      allow update: if isAdmin() && isValidGrievance(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidGrievance(data) {
      return data.keys().hasAll(['ticketNo', 'categoryEn', 'categoryHi', 'content', 'isAnonymous', 'submittedDate', 'status'])
        && data.ticketNo is string
        && data.categoryEn is string
        && data.categoryHi is string
        && data.content is string && data.content.size() <= 5000
        && data.isAnonymous is bool
        && data.status is string
        && data.submittedDate is string;
    }

    // 8. Certificate Requests Collection
    match /certificates/{requestId} {
      allow read: if isSignedIn() && (isStaff() || resource.data.studentEmail == request.auth.token.email);
      allow create: if isVerifiedUser() && isValidCertificateRequest(request.resource.data);
      allow update: if isSignedIn() && (
        isAdmin() || (
          resource.data.studentEmail == request.auth.token.email &&
          resource.data.status == 'Applied' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reasonEn', 'reasonHi', 'type', 'className', 'academicYear'])
        )
      );
      allow delete: if isAdmin();
    }

    function isValidCertificateRequest(data) {
      return data.keys().hasAll(['referenceNo', 'studentNameEn', 'studentNameHi', 'rollNo', 'className', 'academicYear', 'type', 'reasonEn', 'reasonHi', 'status', 'appliedDate'])
        && data.referenceNo is string
        && data.studentNameEn is string
        && data.studentNameHi is string
        && data.rollNo is string
        && data.className is string
        && data.academicYear is string
        && data.type is string
        && data.reasonEn is string && data.reasonEn.size() <= 2000
        && data.reasonHi is string && data.reasonHi.size() <= 2000
        && data.status is string
        && data.appliedDate is string;
    }

    // 9. Admins Collection
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidAdminRecord(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidAdminRecord(data) {
      return data.keys().hasAll(['uid', 'role', 'permissions'])
        && data.uid is string
        && data.role is string && (data.role == 'ADMIN' || data.role == 'TEACHER');
    }
  }
}
